# ──────────────────────────────────────────────────────────────────────────────
#  AI Opportunity Scout — Environment Configuration
#  Copy this to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME="AI Opportunity Scout"
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_opportunity_scout
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_opportunity_scout

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@aiopportunityscout.com
SMTP_FROM_NAME="AI Opportunity Scout"

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── GitHub OAuth ────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=UTC
SCHEDULER_INTERVAL_HOURS=6
SCHEDULER_DAILY_DIGEST_HOUR=8
SCHEDULER_DAILY_DIGEST_MINUTE=0
SCHEDULER_REMINDER_HOUR=7
SCHEDULER_REMINDER_MINUTE=0
SCHEDULER_MAX_CRAWL_RETRIES=3
SCHEDULER_CRAWL_RETRY_DELAY_SECONDS=300
SCHEDULER_LOCK_TTL_SECONDS=3600

# ── Storage ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
