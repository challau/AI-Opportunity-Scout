# ============================================================
# AI Opportunity Scout — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git.
#
# PRODUCTION DEPLOYMENT CHECKLIST:
#   DATABASE_URL  → Neon PostgreSQL connection string
#   REDIS_URL     → Upstash Redis URL
#   SECRET_KEY    → python -c "import secrets; print(secrets.token_hex(32))"
#   OPENAI_API_KEY → your OpenAI key
#   CORS_ORIGINS  → ["https://your-app.vercel.app"]
# ============================================================

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=AI Opportunity Scout
APP_VERSION=1.0.0
APP_ENV=production
APP_URL=https://your-app.vercel.app
API_URL=https://your-backend.railway.app
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Swagger Docs ─────────────────────────────────────────────────────────────
# Set to true to enable /docs on Railway even in production
DOCS_ENABLED=true

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Async URL for FastAPI/SQLAlchemy runtime
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?ssl=require
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
# Use the rediss:// TLS URL from Upstash console
REDIS_URL=rediss://default:PASSWORD@ep-xxx.upstash.io:6379

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend.railway.app/api/auth/google/callback

# ─── GitHub OAuth (optional) ──────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-backend.railway.app/api/auth/github/callback

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=AI Opportunity Scout
SENDGRID_API_KEY=

# ─── Telegram Bot (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://your-backend.railway.app/api/telegram/webhook

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
SCHEDULER_INTERVAL_HOURS=6
SCHEDULER_DAILY_DIGEST_HOUR=8
SCHEDULER_DAILY_DIGEST_MINUTE=0
SCHEDULER_REMINDER_HOUR=7
SCHEDULER_REMINDER_MINUTE=0
SCHEDULER_MAX_CRAWL_RETRIES=3
SCHEDULER_CRAWL_RETRY_DELAY_SECONDS=300
SCHEDULER_LOCK_TTL_SECONDS=3600

# ─── Crawling ─────────────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
CRAWL_TIMEOUT=30
MAX_RETRIES=3
RATE_LIMIT_DELAY=2.0
PLAYWRIGHT_ENABLED=false

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================================
# FRONTEND VARIABLES (set in Vercel dashboard, not here)
# ============================================================
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
